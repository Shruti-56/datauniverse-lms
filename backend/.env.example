# =========================
# Database
# =========================
# For shared hosting (Hostinger), use connection_limit=5 and pool_timeout=10 to prevent
# hanging connections that accumulate and exhaust the process limit:
# DATABASE_URL="mysql://user:pass@host:3306/DataUniverse?connection_limit=5&pool_timeout=10&connect_timeout=10"
DATABASE_URL="mysql://root:your_password@localhost:3306/DataUniverse"

# =========================
# JWT Authentication
# =========================
JWT_SECRET=change_this_to_a_secure_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# =========================
# Server
# =========================
# Port the backend listens on. Frontend uses same origin (/api), so open http://localhost:3000
PORT=3000
# Set NODE_ENV=production when deploying. Enables 0.0.0.0 binding and production optimizations.
NODE_ENV=development

# =========================
# AWS S3 (for video storage)
# =========================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-bucket-name

# =========================
# Cashfree Payment Gateway
# =========================
# Get credentials from: https://merchant.cashfree.com → Developers → API Keys
# Use sandbox for testing; set CASHFREE_ENV=production for live payments
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=sandbox

# =========================
# Stripe (Landing page payments)
# =========================
# Used for ads landing page ₹99 payments (Stripe Checkout)
STRIPE_SECRET_KEY=sk_test_...
# Optional (recommended if you later add webhook verification)
# STRIPE_WEBHOOK_SECRET=whsec_...

# =========================
# Email (SMTP) - Required for welcome, password reset, and other emails
# =========================
# Without SMTP_USER and SMTP_PASS, no emails are sent.
#
# --- Outlook / Microsoft 365 (e.g. admin@datauniverse.in) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=admin@datauniverse.in
SMTP_PASS=your_outlook_password_or_app_password
SMTP_FROM=DataUniverse <admin@datauniverse.in>
#
# --- Gmail (alternative) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM=DataUniverse <your_email@gmail.com>
# If port 587 is blocked, try port 465 with SMTP_SECURE=true.
# Instructor gets submission emails only if the student has an assigned instructor (Admin → Students).

# =========================
# Frontend URL & CORS (REQUIRED for production)
# =========================
# FRONTEND_URL: Used in email links (login, reset password, course access). Set to your live domain.
# CORS_ORIGINS: Comma-separated allowed origins. Include your production URL for API requests to work.
#
# Development:
FRONTEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000
#
# Production example (replace with your domain):
# FRONTEND_URL=https://datauniverse.in
# CORS_ORIGINS=https://datauniverse.in,https://www.datauniverse.in

# =========================
# Live lecture reminders (mail 10 min before scheduled time)
# =========================
# Server uses this for "10 min before" reminder window. Set to your institute timezone.
TZ=Asia/Kolkata
